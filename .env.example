# --- Postgres ---
POSTGRES_USER=elyzian
POSTGRES_PASSWORD=elyzian_dev_password
POSTGRES_DB=elyzian
POSTGRES_PORT=5432
DATABASE_URL=postgresql://elyzian:elyzian_dev_password@localhost:5432/elyzian?schema=public

# --- Redis ---
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# --- MinIO ---
MINIO_ROOT_USER=elyzian_admin
MINIO_ROOT_PASSWORD=elyzian_dev_password
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ENDPOINT=localhost
MINIO_USE_SSL=false
MINIO_BUCKET=elyzian-files

# --- LDAP (Active Directory in production, OpenLDAP locally / in CI) ---
LDAP_URL=ldap://localhost:1389
LDAP_BIND_DN=cn=admin,dc=elyzian,dc=local
LDAP_BIND_PASSWORD=elyzian_dev_password
LDAP_ADMIN_PASSWORD=elyzian_dev_password
LDAP_BASE_DN=dc=elyzian,dc=local
LDAP_USER_SEARCH_BASE=ou=people,dc=elyzian,dc=local
LDAP_GROUP_SEARCH_BASE=ou=groups,dc=elyzian,dc=local
LDAP_USERNAME_ATTRIBUTE=uid
LDAP_UNIQUE_ID_ATTRIBUTE=entryUUID
LDAP_PORT=1389

# --- JWT / sessions (TTLs in seconds) ---
JWT_ACCESS_SECRET=dev_access_secret_change_me
JWT_REFRESH_SECRET=dev_refresh_secret_change_me
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800

# --- API ---
PORT=3000
NODE_ENV=development
WEB_ORIGIN=http://localhost:5173

# --- GLPI (ticketing) ---
GLPI_URL=http://localhost:8080
GLPI_APP_TOKEN=dev_glpi_app_token_change_me
GLPI_USER_TOKEN=dev_glpi_user_token_change_me
# Optional: unset skips webhook signature verification (dev-only)
GLPI_WEBHOOK_SECRET=
GLPI_WEBHOOK_TICKET_ID_FIELD=id

# --- Tactical RMM (device monitoring/alerting) ---
RMM_URL=https://api.rmm.example.org
RMM_API_KEY=dev_rmm_api_key_change_me
# Optional: unset skips webhook bearer-token verification (dev-only)
RMM_WEBHOOK_SECRET=
# Existing channel name (not display name) that alerts are posted into
RMM_ALERT_CHANNEL_NAME=ti
# Minimum severity that auto-opens a GLPI ticket: info | warning | error | off
RMM_AUTO_TICKET_SEVERITY=error

# --- Web (must be VITE_-prefixed to reach client bundle) ---
VITE_API_URL=http://localhost:3000
VITE_WS_URL=ws://localhost:3000

# --- Edge / TLS (only for the production Caddy overlay; see docs/deploy-edge.md) ---
# Domains must resolve to the host running the edge, with ports 80/443 open.
# Caddy obtains + auto-renews trusted Let's Encrypt certs for both.
APP_DOMAIN=app.example.org
API_DOMAIN=api.example.org
ACME_EMAIL=admin@example.org
