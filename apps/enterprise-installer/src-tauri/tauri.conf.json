{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Elyzian Enterprise Installer",
  "version": "0.1.0",
  "identifier": "br.gov.novaserrana.elyzian.installer",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1421",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Elyzian — Enterprise Setup",
        "width": 960,
        "height": 700,
        "minWidth": 820,
        "minHeight": 600,
        "resizable": true,
        "visible": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "resources": {
      "../../../docker": "docker"
    },
    "windows": {
      "nsis": {
        "installMode": "perMachine"
      }
    }
  }
}
