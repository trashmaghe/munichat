{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Elyzian",
  "version": "0.1.0",
  "identifier": "br.gov.novaserrana.elyzian.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Elyzian",
        "width": 1120,
        "height": 760,
        "minWidth": 400,
        "minHeight": 560,
        "resizable": true,
        "visible": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": false,
    "windows": {
      "nsis": {
        "installMode": "perMachine"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDc3RTkxQTA5Mjk2NzdCNUMKUldSY2UyY3BDUnJwZDN4cXAwTWhiMnhmczhyYUdKZ2YxbTQ5U0JRbkFNMEU4ZmtONWVnZDFYVGcK",
      "endpoints": [
        "https://github.com/trashmaghe/elyzian/releases/latest/download/latest.json"
      ]
    }
  }
}
